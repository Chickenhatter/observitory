	<body>
		<div id="my_website">
			<div class = "flex justify-end">
				<h1 class="text-yellow-500 text-right text-[10vw] font-['Arial'] font-bold">
					jms
				</h1>
				<div class="text-yellow-500 pt-[5vw] pr-[5vw] text-[4vw] font-['Arial'] font-bold w-[30%] leading-none">
					corner of the cosmos
				</div>
			</div>
		</div>
		<div id="Hello">
			<h2 class="text-yellow-400 font-['Arial'] font-bold pt-[20vw] text-[7vw] pl-[3vw]">
				Hey,
			</h2>
			<div class="pl-[10vw] text-yellow-400 font-['Arial'] font-bold pt-[2vw] text-[2vw]">
