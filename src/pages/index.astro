			<img src="../../assets/grass.png" class="pt-[10vw]">
			<img src="../../assets/observitory.png" id='observitory' class="absolute top-[270vw] darkness">
		</div>
		
		<div class="final_section">
			<div id="firstlast_box" class="pl-[21vw] pt-[80vw]  font-['Arial'] font-bold text-[1.5vw] pr-[27vw] inline-block flex inline">
