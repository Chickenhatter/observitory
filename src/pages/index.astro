				<div class="text-yellow-400 font-['Arial'] font-bold pt-[20vw] text-[2vw] ml-[10vw] mr-[10vw] mb-[20vw]">This is this own website you are currently on</div>
			</div>

			<div class="ml-[10vw] pt-[20vw] text-yellow-400 font-['Arial'] font-bold pt-[20vw] text-[4vw]">
				Walks in NZ bush
			</div>
			<div class="flex justify-end items-center">
				<div class="ml-[20vw] bg-[#574d87] px-[3vw] rounded-[2vw]  py-[3vw] pl-[3vw] w-[40vw]">
					<img src="/assets/bush_walk.png" class=" rounded-[2vw] w-[40vw]">
				</div>
			<div class="text-yellow-400 font-['Arial'] font-bold pt-[20vw] text-[2vw] ml-[10vw] mr-[10vw] mb-[20vw] max-w-[20vw] text-left">This is in a walk 5 minutes from my house, I love nz for its walks</div>
			</div>
			
			<div class="ml-[10vw] pt-[20vw]pt-[20vw] text-yellow-400 font-['Arial'] font-bold pt-[20vw] text-[4vw]">
